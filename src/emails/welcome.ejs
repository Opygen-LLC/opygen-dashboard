<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta http-equiv="x-ua-compatible" content="ie=edge">
  <title>Welcome to Opygen Workspace</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style type="text/css">
    body, table, td, a { -ms-text-size-adjust: 100%; -webkit-text-size-adjust: 100%; }
    table, td { mso-table-rspace: 0pt; mso-table-lspace: 0pt; }
    img { -ms-interpolation-mode: bicubic; }
    body {
      background-color: #f8fafc;
      font-family: -apple-system, BlinkMacSystemFont, "Inter", "Segoe UI", Roboto, sans-serif;
      margin: 0 !important;
      padding: 0 !important;
      width: 100% !important;
    }
    a[x-apple-data-detectors] {
      color: inherit !important;
      text-decoration: none !important;
      font-size: inherit !important;
      font-family: inherit !important;
      font-weight: inherit !important;
      line-height: inherit !important;
    }
    @media screen and (max-width: 600px) {
      .main-card {
        padding: 24px !important;
        border-radius: 12px !important;
      }
      .btn {
        display: block !important;
        width: auto !important;
        text-align: center !important;
      }
    }
  </style>
</head>
<body style="background-color: #f8fafc; padding: 40px 0;">
  <table border="0" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td align="center">
        <!--[if (gte mso 9)|(IE)]>
        <table align="center" border="0" cellspacing="0" cellpadding="0" width="600">
        <tr>
        <td align="center" valign="top" width="600">
        <![endif]-->
        <table border="0" cellpadding="0" cellspacing="0" width="100%" style="max-width: 540px;">
          <!-- BRAND ICON/LOGO -->
          <tr>
            <td align="center" style="padding: 0px 0px 24px 0px;">
              <table border="0" cellpadding="0" cellspacing="0">
                <tr>
                  <td align="center" style="background-color: #4f46e5; border-radius: 12px; padding: 10px; display: inline-block;">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display: block; margin: 0;"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="8.5" cy="7" r="4"></circle><line x1="20" y1="8" x2="20" y2="14"></line><line x1="23" y1="11" x2="17" y2="11"></line></svg>
                  </td>
                </tr>
                <tr>
                  <td align="center" style="padding-top: 12px;">
                    <h1 style="margin: 0; font-size: 24px; font-weight: 800; letter-spacing: -0.04em; color: #0f172a;">
                      Opygen <span style="font-weight: 400; color: #4f46e5;">Workspace</span>
                    </h1>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          
          <!-- MAIN CARD -->
          <tr>
            <td align="left" class="main-card" style="background-color: #ffffff; padding: 40px; border-radius: 20px; border: 1px solid #e2e8f0; box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05), 0 4px 6px -4px rgba(0, 0, 0, 0.05);">
              <h2 style="margin: 0 0 16px 0; font-size: 20px; font-weight: 800; color: #0f172a; letter-spacing: -0.02em;">
                Welcome to the Team
              </h2>
              <p style="margin: 0 0 20px 0; font-size: 14px; line-height: 22px; color: #334155;">
                Hello <strong><%= name %></strong>,
              </p>
              <p style="margin: 0 0 24px 0; font-size: 14px; line-height: 22px; color: #475569;">
                An administrator has created a co-founder account for you on the Opygen Project Management Dashboard. Use the temporary credentials below to access your space:
              </p>
              
              <!-- CREDENTIALS CARD -->
              <div style="background-color: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px; padding: 20px; margin-bottom: 28px;">
                <table border="0" cellpadding="0" cellspacing="0" width="100%">
                  <tr>
                    <td style="padding-bottom: 12px; font-size: 13px; color: #64748b; font-weight: 600; width: 100px;">EMAIL:</td>
                    <td style="padding-bottom: 12px; font-size: 14px; color: #0f172a; font-weight: 700; word-break: break-all;"><%= email %></td>
                  </tr>
                  <tr>
                    <td style="font-size: 13px; color: #64748b; font-weight: 600;">PASSWORD:</td>
                    <td style="font-size: 14px; color: #e11d48; font-weight: 700; font-family: monospace; letter-spacing: 0.05em;"><%= password %></td>
                  </tr>
                </table>
              </div>

              <!-- REQUIRED CHANGE PASSWORD WARNING -->
              <div style="background-color: #fff1f2; border-left: 4px solid #f43f5e; border-radius: 0 8px 8px 0; padding: 16px; margin-bottom: 28px;">
                <p style="margin: 0; font-size: 13px; line-height: 18px; color: #9f1239;">
                  <strong>Action Required:</strong> This password is a <strong>one-time passkey</strong>. Upon your initial sign-in, you will be automatically prompted to configure a new personal password to continue.
                </p>
              </div>

              <!-- CTA BUTTON -->
              <table border="0" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 28px;">
                <tr>
                  <td align="center">
                    <a href="<%= loginUrl %>" target="_blank" class="btn" style="background-color: #4f46e5; border-radius: 10px; color: #ffffff; display: inline-block; font-size: 14px; font-weight: 700; line-height: 50px; text-align: center; text-decoration: none; padding: 0 36px; box-shadow: 0 4px 12px rgba(79, 70, 229, 0.25); transition: background-color 0.2s;">
                      Log In & Activate Account
                    </a>
                  </td>
                </tr>
              </table>
              
              <hr style="border: 0; border-top: 1px solid #f1f5f9; margin: 24px 0;">
              
              <!-- FALLBACK LINK -->
              <p style="margin: 0; font-size: 11px; line-height: 16px; color: #64748b; word-break: break-all;">
                If the button above does not work, copy and paste this URL into your browser:<br>
                <a href="<%= loginUrl %>" target="_blank" style="color: #4f46e5; text-decoration: underline; font-weight: 500;"><%= loginUrl %></a>
              </p>
            </td>
          </tr>
          
          <!-- FOOTER -->
          <tr>
            <td align="center" style="padding: 32px 24px 0px 24px;">
              <p style="margin: 0 0 6px 0; font-size: 11px; font-weight: 700; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.08em;">
                Opygen Co-Founder Dashboard
              </p>
              <p style="margin: 0; font-size: 11px; color: #cbd5e1;">
                Internal Notification. Please do not forward.
              </p>
            </td>
          </tr>
        </table>
        <!--[if (gte mso 9)|(IE)]>
        </td>
        </tr>
        </table>
        <![endif]-->
      </td>
    </tr>
  </table>
</body>
</html>
